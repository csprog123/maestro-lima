# ─── Supabase (optional for the demo) ────────────────────────────────
# If unset, the app runs entirely on the in-repo seed data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Meta WhatsApp Cloud API (stubbed unless configured) ─────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=maestro_verify_token

# ─── Culqi payments (stubbed) ────────────────────────────────────────
NEXT_PUBLIC_CULQI_PUBLIC_KEY=
